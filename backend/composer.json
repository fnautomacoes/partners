{
    "name": "pacoticket/parceiros",
    "description": "PacoTicket Partners Management System",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "firebase/php-jwt": "^6.10",
        "phpmailer/phpmailer": "^6.9",
        "predis/predis": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Core\\": "src/Core/",
            "Controllers\\": "src/Controllers/",
            "Services\\": "src/Services/",
            "Helpers\\": "src/Helpers/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "audit": {
            "abandoned": "ignore"
        },
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "policy": {
        "advisories": {
            "ignore": ["PKSA-y2cr-5h3j-g3ys"]
        }
    }
}
