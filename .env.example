# Database (PostgreSQL)
DB_HOST=your-postgres-host
DB_PORT=5432
DB_NAME=pacoticket_parceiros
DB_USER=your-db-user
DB_PASS=your-db-password

# JWT Secrets (generate with: openssl rand -hex 64)
JWT_SECRET=your-64-char-hex-secret-for-access-tokens
JWT_REFRESH_SECRET=your-64-char-hex-secret-for-refresh-tokens
JWT_EXPIRES_IN=28800
JWT_REFRESH_EXPIRES_IN=604800

# Redis
REDIS_URL=redis://redis:6379

# Application
APP_ENV=production
APP_URL=https://your-domain.com
DOMAIN=your-domain.com

# SMTP (Email)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_MODE=starttls
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@your-domain.com

# PacoTicket API Integration
PACOTICKET_API_URL=https://api.pacoticket.com
PACOTICKET_BEARER_TOKEN=your-pacoticket-api-token

# Gotenberg (PDF generation)
GOTENBERG_URL=http://gotenberg:3000
PDF_STORAGE_PATH=/data/pdfs

# Docker Registry (for Swarm deployment)
REGISTRY=your-registry.com
TAG=latest
